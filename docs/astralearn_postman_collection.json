{
  "info": {
    "_postman_id": "a5e8211b-c124-4f0e-b9b4-0c6efae78cc5",
    "name": "AstraLearn AI API Collection",
    "description": "Pre-configured test suite for AstraLearn AI HTTP routes, Authentication and WebSockets.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. User Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"securedpassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/auth/signup",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "auth",
                "signup"
              ]
            },
            "description": "Registers a new user with an email and password."
          },
          "response": []
        },
        {
          "name": "2. User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson.success && responseJson.data) {",
                  "    pm.collectionVariables.set(\"jwtToken\", responseJson.data.token);",
                  "    console.log(\"Saved jwtToken to Collection Variables:\", responseJson.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"securedpassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticates user credentials and saves the returned JWT token to Collection variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Curriculum Intake (Secure)",
      "item": [
        {
          "name": "1. Start Curriculum Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson.success && responseJson.data) {",
                  "    pm.collectionVariables.set(\"goalId\", responseJson.data.goalId);",
                  "    console.log(\"Saved goalId to Collection Variables:\", responseJson.data.goalId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goalText\": \"I want to learn Generative AI and build a RAG product recommendation system.\",\n  \"category\": \"job_project\",\n  \"durationDays\": 21\n}"
            },
            "url": {
              "raw": "http://localhost:8000/curriculum/start",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "curriculum",
                "start"
              ]
            },
            "description": "Initializes a learning goal session for the authenticated user, creates Profile/Curriculum records, and saves the goalId in Collection variables."
          },
          "response": []
        },
        {
          "name": "2. Get Curriculum Roadmap",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwtToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/curriculum/{{goalId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "curriculum",
                "{{goalId}}"
              ]
            },
            "description": "Retrieves the full curriculum roadmap (phases, modules, lessons) for the given Goal ID."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "goalId",
      "value": "PASTE_GOAL_ID_HERE",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "PASTE_JWT_TOKEN_HERE",
      "type": "string"
    }
  ]
}
