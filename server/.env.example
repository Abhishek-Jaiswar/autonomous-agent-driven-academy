# AstraLearn Server Environment Template

# Server Port & Environment
PORT=8000
NODE_ENV=production
CLIENT_URL=https://your-client-domain.vercel.app

# Google Gemini API Key
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Database Connection (PostgreSQL / Supabase / Neon / Render)
DATABASE_URL="postgresql://user:password@hostname:5432/astralearn?sslmode=require"

# Redis Connection (Upstash / Redis Cloud / AWS ElastiCache)
REDIS_URL="redis://default:password@hostname:port"

# Pinecone Vector Database Config
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_INDEX="astralearn"

# Security & Authentication
JWT_SECRET="generate_a_secure_32_byte_secret_here"

# LangSmith Observability Tracing (Optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=astralearn-ai
